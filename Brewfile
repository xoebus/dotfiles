# Core
brew "neovim"
brew "git"
brew "tmux"

# Neovim dependencies
brew "ripgrep"       # telescope live grep
brew "fd"            # telescope file finder
brew "tree-sitter"   # syntax parsing

# Formatters & language tools
brew "stylua"        # Lua formatter (conform.nvim)
brew "gofumpt"       # Go formatter (conform.nvim)
brew "go"            # required for gopls, goimports

# Language servers (installed via go install, not brew)
# gopls:     go install golang.org/x/tools/gopls@latest
# goimports: go install golang.org/x/tools/cmd/goimports@latest

# Runtimes (for LSP servers)
brew "node"          # required for JSON/YAML/TS language servers
brew "zig"

# Rust toolchain
brew "rustup"
